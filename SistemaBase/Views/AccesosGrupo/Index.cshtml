@model IEnumerable<SistemaBase.Models.GruposUsuario>

@{
    ViewData["Title"] = "Accesos por grupo";
}

<div class="mx-n4 px-4 mx-lg-n6 px-lg-6 bg-white pt-6 pb-6 border-y border-300">
    <div class="row align-items-end justify-content-between pb-4 g-3">
        <div class="col-auto">
            <h3 class="mb-2">Accesos por grupo</h3>
            <p class="text-700 mb-0">Seleccione que pantallas puede abrir cada grupo de usuarios.</p>
        </div>
        <div class="col-auto">
            <form asp-action="SincronizarPantallas" method="post">
                @Html.AntiForgeryToken()
                <button class="btnAbm" type="submit"><i class="fa fa-refresh"></i> Sincronizar pantallas</button>
            </form>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success" role="alert">@TempData["Success"]</div>
    }

    <div class="table-responsive mx-n1 px-1Latest">
        <table class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th class="text-center col-1">Codigo</th>
                    <th>Grupo</th>
                    <th class="text-center col-2"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-center">@item.IdGrupo</td>
                        <td>@item.Descripcion</td>
                        <td class="text-center">
                            <button class="btnAbm" type="button" onclick="openAbmModal('@Url.Action("Asignar", new { id = item.IdGrupo })')">
                                <i class="fa fa-key"></i> Permisos
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="abmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content" id="abmModalContent"></div>
    </div>
</div>

@section Scripts {
    <script>
        async function openAbmModal(url) {
            const response = await fetch(url);
            document.getElementById('abmModalContent').innerHTML = await response.text();
            new bootstrap.Modal(document.getElementById('abmModal')).show();
        }
    </script>
}
