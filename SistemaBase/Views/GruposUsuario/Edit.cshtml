@model SistemaBase.Models.GruposUsuario

@{
    Layout = "";
}

<div class="modal-header">
    <h5 class="modal-title">Editar grupo</h5>
    <button class="btn p-1" type="button" data-bs-dismiss="modal" aria-label="Close"><i class="fa fa-times"></i></button>
</div>
<div class="modal-body">
    <form asp-action="Edit" asp-route-id="@Model.IdGrupo" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input type="hidden" asp-for="IdGrupo" />
        <div class="mb-3">
            <label asp-for="IdGrupo" class="form-label fw-semibold">Codigo</label>
            <input asp-for="IdGrupo" class="form-control" disabled />
        </div>
        <div class="mb-3">
            <label asp-for="Descripcion" class="form-label fw-semibold">Descripcion</label>
            <input asp-for="Descripcion" class="form-control" maxlength="40" />
            <span asp-validation-for="Descripcion" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="IdFacultad" class="form-label fw-semibold">Facultad</label>
            <select asp-for="IdFacultad" class="form-select" asp-items="ViewBag.IdFacultad">
                <option value="">Sin restriccion</option>
            </select>
            <span asp-validation-for="IdFacultad" class="text-danger"></span>
        </div>
        <button class="btnAbm" type="submit"><i class="fa fa-save"></i> Guardar</button>
        <button class="btnAbmCancelar" type="button" data-bs-dismiss="modal">Cancelar</button>
    </form>
</div>
