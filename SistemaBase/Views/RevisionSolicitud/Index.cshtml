@model IEnumerable<SistemaBase.ModelsCustom.SolicitudRevision>

@{
    ViewData["Title"] = "Revision de solicitudes";
}

<div class="mx-n4 px-4 mx-lg-n6 px-lg-6 bg-white pt-6 pb-6 border-y border-300">
    <div class="row align-items-end justify-content-between pb-4 g-3">
        <div class="col-auto">
             <h3 class="mb-2">Revision de solicitudes de tesis</h3> 
            <p class="text-700 mb-0">Facultad: <strong>@ViewBag.FacultadUsuario</strong></p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success" role="alert">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger" role="alert">@TempData["Error"]</div>
    }

    <form asp-action="Index" method="get" class="row g-3 align-items-end mb-4">
        <div class="col-12 col-md-5 col-xl-4">
            <label class="form-label fw-semibold" for="idCarrera">Carrera</label>
            <select class="form-select" id="idCarrera" name="idCarrera" asp-items="ViewBag.IdCarrera">
                <option value="">Todas</option>
            </select>
        </div>
        <div class="col-auto">
            <button class="btnAbm" type="submit"><i class="fa fa-search"></i> Filtrar</button>
            <a class="btnAbmCancelar" asp-action="Index"><i class="fa fa-times"></i> Limpiar</a>
        </div>
    </form>

    <div class="table-responsive mx-n1 px-1Latest">
        <table class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th class="text-center col-1">Nro.</th>
                    <th>Fecha</th>
                    <th>Alumno</th>
                    <th>Documento</th>
                    <th>Facultad</th>
                    <th>Carrera</th>
                    <th>Tutor</th>
                    <th>Estado</th>
                    <th class="text-center col-1"></th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="9" class="text-center text-700 py-4">No existen solicitudes registradas.</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center">@item.IdSolicitudTesis</td>
                            <td>@item.FechaSolicitud.ToString("dd/MM/yyyy")</td>
                            <td>
                                <div class="fw-semibold">@item.Alumno</div>
                                <div class="text-700 fs--1">@item.Tema</div>
                            </td>
                            <td>@item.Documento</td>
                            <td>@item.Facultad</td>
                            <td>@item.Carrera</td>
                            <td>@item.Tutor</td>
                            <td><span class="badge bg-info">@item.Estado</span></td>
                            <td class="text-center">
                                <a class="btnAbm" asp-action="Detalle" asp-route-id="@item.IdSolicitudTesis">
                                    <i class="fa fa-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
