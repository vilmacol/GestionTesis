@model SistemaBase.Models.Persona



        @{
        ViewData["Title"] = "Edit";
        Layout = "";
         string namecheck = "";
        }
        
    <div class="modal fade " id="detailsModal" tabindex="-1" aria-labelledby="detailsModallLabel" style="display: none;" aria-modal="true" role="dialog">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="detailsModalLabel">Persona</h5>
                    <button class="btn p-1" type="button" data-bs-dismiss="modal" aria-label="Close" id="editmodal"><svg class="svg-inline--fa fa-xmark fs--1" aria-hidden="true" focusable="false" data-prefix="fas" data-icon="xmark" role="img" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 512" data-fa-i2svg=""><path fill="currentColor" d="M310.6 361.4c12.5 12.5 12.5 32.75 0 45.25C304.4 412.9 296.2 416 288 416s-16.38-3.125-22.62-9.375L160 301.3L54.63 406.6C48.38 412.9 40.19 416 32 416S15.63 412.9 9.375 406.6c-12.5-12.5-12.5-32.75 0-45.25l105.4-105.4L9.375 150.6c-12.5-12.5-12.5-32.75 0-45.25s32.75-12.5 45.25 0L160 210.8l105.4-105.4c12.5-12.5 32.75-12.5 45.25 0s12.5 32.75 0 45.25l-105.4 105.4L310.6 361.4z"></path></svg><!-- <span class="fas fa-times fs--1"></span> Font Awesome fontawesome.com --></button>
                </div>
                <div class="modal-body">
                    <form asp-action="Edit" id="FormModal" onsubmit="submitforms(event,'Edit' ,'FormModal')" class="mb-0">
                        <div class="row g-0 mt-0 mb-0">
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                                        <div class="col-12">
                                            <div class="row">
                                                <div class="col-4">
                                                    <label class="form-control-label fs-0 subTitleModal text-900" asp-for="IdPersona"></label>
                                                </div>
                                                <div class="col-8">
                                                        <input class="form-control" asp-for="IdPersona" />
                                                    <span asp-validation-for="IdPersona" class="text-danger k-invalid-msg" data-for="IdPersona"></span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-12">
                                            <div class="row">
                                                <div class="col-4">
                                                    <label class="form-control-label fs-0 subTitleModal text-900" asp-for="Nombre"></label>
                                                </div>
                                                <div class="col-8">
                                                        <input class="form-control" asp-for="Nombre" />
                                                    <span asp-validation-for="Nombre" class="text-danger k-invalid-msg" data-for="Nombre"></span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-12">
                                            <div class="row">
                                                <div class="col-4">
                                                    <label class="form-control-label fs-0 subTitleModal text-900" asp-for="Sexo"></label>
                                                </div>
                                                <div class="col-8">
                                                        <input class="form-control" asp-for="Sexo" />
                                                    <span asp-validation-for="Sexo" class="text-danger k-invalid-msg" data-for="Sexo"></span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-12">
                                            <div class="row">
                                                <div class="col-4">
                                                    <label class="form-control-label fs-0 subTitleModal text-900" asp-for="FecNacimiento"></label>
                                                </div>
                                                <div class="col-8">
                                                        <input class="form-control" asp-for="FecNacimiento" />
                                                    <span asp-validation-for="FecNacimiento" class="text-danger k-invalid-msg" data-for="FecNacimiento"></span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-12">
                                            <div class="row">
                                                <div class="col-4">
                                                    <label class="form-control-label fs-0 subTitleModal text-900" asp-for="FecAlta"></label>
                                                </div>
                                                <div class="col-8">
                                                        <input class="form-control" asp-for="FecAlta" />
                                                    <span asp-validation-for="FecAlta" class="text-danger k-invalid-msg" data-for="FecAlta"></span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-12">
                                            <div class="row">
                                                <div class="col-4">
                                                    <label class="form-control-label fs-0 subTitleModal text-900" asp-for="FecActualizacion"></label>
                                                </div>
                                                <div class="col-8">
                                                        <input class="form-control" asp-for="FecActualizacion" />
                                                    <span asp-validation-for="FecActualizacion" class="text-danger k-invalid-msg" data-for="FecActualizacion"></span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-12">
                                            <div class="row">
                                                <div class="col-4">
                                                    <label class="form-control-label fs-0 subTitleModal text-900" asp-for="EstadoCivil"></label>
                                                </div>
                                                <div class="col-8">
                                                        <input class="form-control" asp-for="EstadoCivil" />
                                                    <span asp-validation-for="EstadoCivil" class="text-danger k-invalid-msg" data-for="EstadoCivil"></span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-12">
                                            <div class="row">
                                                <div class="col-4">
                                                    <label class="form-control-label fs-0 subTitleModal text-900" asp-for="Email"></label>
                                                </div>
                                                <div class="col-8">
                                                        <input class="form-control" asp-for="Email" />
                                                    <span asp-validation-for="Email" class="text-danger k-invalid-msg" data-for="Email"></span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-12">
                                            <div class="row">
                                                <div class="col-4">
                                                    <label class="form-control-label fs-0 subTitleModal text-900" asp-for="DireccionParticular"></label>
                                                </div>
                                                <div class="col-8">
                                                        <input class="form-control" asp-for="DireccionParticular" />
                                                    <span asp-validation-for="DireccionParticular" class="text-danger k-invalid-msg" data-for="DireccionParticular"></span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-12">
                                            <div class="row">
                                                <div class="col-4">
                                                    <label class="form-control-label fs-0 subTitleModal text-900" asp-for="SitioWeb"></label>
                                                </div>
                                                <div class="col-8">
                                                        <input class="form-control" asp-for="SitioWeb" />
                                                    <span asp-validation-for="SitioWeb" class="text-danger k-invalid-msg" data-for="SitioWeb"></span>
                                                </div>
                                            </div>
                                        </div>
                            <div class="text-center" id="loader_inv" style="visibility: hidden;">
                                <div class="spinner-border" role="status">
                                    <span class="sr-only"></span>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button class="btnAbm" type="submit">
                                    <span class="btn-label"><i class="fa fa-save"></i></span> Guardar
                                </button>
                                <button class="btnAbmCancelar" id="closededit" type="button" data-bs-dismiss="modal">
                                    <span class="btn-label"><i class="fa fa-remove"></i></span> Cancelar
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

        @section Scripts {
        @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
        }
