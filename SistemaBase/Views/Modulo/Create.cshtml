@model SistemaBase.Models.Modulo

@{
    Layout = "";
}

<div class="modal-header">
    <h5 class="modal-title">Nuevo modulo</h5>
    <button class="btn p-1" type="button" data-bs-dismiss="modal" aria-label="Close"><i class="fa fa-times"></i></button>
</div>
<div class="modal-body">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="mb-3">
            <label asp-for="IdModulo" class="form-label fw-semibold">Codigo</label>
            <input asp-for="IdModulo" class="form-control" maxlength="2" required />
            <span asp-validation-for="IdModulo" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Descripcion" class="form-label fw-semibold">Descripcion</label>
            <input asp-for="Descripcion" class="form-control" maxlength="80" />
            <span asp-validation-for="Descripcion" class="text-danger"></span>
        </div>
        <button class="btnAbm" type="submit"><i class="fa fa-save"></i> Guardar</button>
        <button class="btnAbmCancelar" type="button" data-bs-dismiss="modal">Cancelar</button>
    </form>
</div>
