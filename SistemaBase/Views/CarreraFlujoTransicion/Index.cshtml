@model IEnumerable<SistemaBase.Models.CarreraFlujoTransicion>

@{
    ViewData["Title"] = "Flujo de tesis";
}

<div class="mx-n4 px-4 mx-lg-n6 px-lg-6 bg-white pt-6 pb-6 border-y border-300">
    <div class="row align-items-end justify-content-between pb-4 g-3">
        <div class="col-auto">
            <h3 class="mb-2">Flujo de tesis</h3>
            <button class="btnAbm" type="button" onclick="openAbmModal('@Url.Action("Create")')"><i class="fa fa-plus"></i> Nuevo</button>
        </div>
    </div>

    <div class="table-responsive mx-n1 px-1Latest">
        <table class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th>Carrera</th>
                    <th>Estado origen</th>
                    <th>Accion</th>
                    <th>Estado destino</th>
                    <th class="text-center">Comentario</th>
                    <th class="text-center">Fecha presentacion</th>
                    <th class="text-center">Activo</th>
                    <th class="text-center col-2"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.IdCarreraNavigation.Descripcion</td>
                        <td>@item.IdEstadoOrigenNavigation.Nombre</td>
                        <td>@item.Accion</td>
                        <td>@item.IdEstadoDestinoNavigation.Nombre</td>
                        <td class="text-center">@(item.RequiereComentario ? "Si" : "No")</td>
                        <td class="text-center">@(item.RequiereFechaPresentacion ? "Si" : "No")</td>
                        <td class="text-center">@item.Activo</td>
                        <td class="text-center">
                            <button class="btnAbm" type="button" onclick="openAbmModal('@Url.Action("Edit", new { id = item.IdCarreraFlujoTransicion })')"><i class="fa fa-pencil"></i></button>
                            <button class="btnEliminar" type="button" onclick="openAbmModal('@Url.Action("Delete", new { id = item.IdCarreraFlujoTransicion })')"><i class="fa fa-trash"></i></button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="abmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content" id="abmModalContent"></div>
    </div>
</div>

@section Scripts {
    <script>
        async function openAbmModal(url) {
            const response = await fetch(url);
            document.getElementById('abmModalContent').innerHTML = await response.text();
            new bootstrap.Modal(document.getElementById('abmModal')).show();
        }
    </script>
}
