@model SistemaBase.Models.CarreraFlujoTransicion

@{
    Layout = "";
}

<div class="modal-header">
    <h5 class="modal-title">Nueva transicion</h5>
    <button class="btn p-1" type="button" data-bs-dismiss="modal" aria-label="Close"><i class="fa fa-times"></i></button>
</div>
<div class="modal-body">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="mb-3"><label asp-for="IdCarrera" class="form-label fw-semibold">Carrera</label><select asp-for="IdCarrera" class="form-select" asp-items="ViewBag.IdCarrera" required><option value="">Seleccione</option></select></div>
        <div class="mb-3"><label asp-for="IdEstadoOrigen" class="form-label fw-semibold">Estado origen</label><select asp-for="IdEstadoOrigen" class="form-select" asp-items="ViewBag.IdEstadoOrigen" required><option value="">Seleccione</option></select></div>
        <div class="mb-3"><label asp-for="Accion" class="form-label fw-semibold">Accion</label><input asp-for="Accion" class="form-control" maxlength="100" required /></div>
        <div class="mb-3"><label asp-for="IdEstadoDestino" class="form-label fw-semibold">Estado destino</label><select asp-for="IdEstadoDestino" class="form-select" asp-items="ViewBag.IdEstadoDestino" required><option value="">Seleccione</option></select></div>
        <div class="form-check mb-2"><input asp-for="RequiereComentario" class="form-check-input" /><label asp-for="RequiereComentario" class="form-check-label">Requiere comentario</label></div>
        <div class="form-check mb-3"><input asp-for="RequiereFechaPresentacion" class="form-check-input" /><label asp-for="RequiereFechaPresentacion" class="form-check-label">Requiere fecha de presentacion</label></div>
        <input type="hidden" asp-for="Activo" />
        <button class="btnAbm" type="submit"><i class="fa fa-save"></i> Guardar</button>
        <button class="btnAbmCancelar" type="button" data-bs-dismiss="modal">Cancelar</button>
    </form>
</div>
