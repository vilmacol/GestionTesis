@model SistemaBase.Models.EstadoSolicitud

@{
    ViewData["Title"] = "Editar estado";
    Layout = "";
}

<div class="modal-header">
    <h5 class="modal-title">Editar estado</h5>
    <button class="btn p-1" type="button" data-bs-dismiss="modal" aria-label="Close"><i class="fa fa-times"></i></button>
</div>
<div class="modal-body">
    <form asp-action="Edit" asp-route-id="@Model.IdEstadoSolicitud" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="IdEstadoSolicitud" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="mb-3"><label class="form-label fw-semibold" asp-for="Nombre">Nombre</label><input class="form-control" asp-for="Nombre" maxlength="80" required /></div>
        <div class="mb-3"><label class="form-label fw-semibold" asp-for="Descripcion">Descripcion</label><textarea class="form-control" asp-for="Descripcion" maxlength="250"></textarea></div>
        <div class="mb-3"><label class="form-label fw-semibold" asp-for="Activo">Activo</label><select class="form-select" asp-for="Activo"><option value="S">S</option><option value="N">N</option></select></div>
        <button class="btnAbm" type="submit"><i class="fa fa-save"></i> Guardar</button>
        <button class="btnAbmCancelar" type="button" data-bs-dismiss="modal">Cancelar</button>
    </form>
</div>
