@model SistemaBase.Models.TipoDocumento

@{
    ViewData["Title"] = "Nuevo tipo de documento";
    Layout = "";
}

<div class="modal-header">
    <h5 class="modal-title">Nuevo tipo de documento</h5>
    <button class="btn p-1" type="button" data-bs-dismiss="modal" aria-label="Close"><i class="fa fa-times"></i></button>
</div>
<div class="modal-body">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="mb-3"><label class="form-label fw-semibold" asp-for="Nombre">Nombre</label><input class="form-control" asp-for="Nombre" maxlength="100" required /></div>
        <div class="mb-3"><label class="form-label fw-semibold" asp-for="Descripcion">Descripcion</label><textarea class="form-control" asp-for="Descripcion" maxlength="250"></textarea></div>
        <input type="hidden" asp-for="Activo" />
        <button class="btnAbm" type="submit"><i class="fa fa-save"></i> Guardar</button>
        <button class="btnAbmCancelar" type="button" data-bs-dismiss="modal">Cancelar</button>
    </form>
</div>
