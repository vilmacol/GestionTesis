@model SistemaBase.Models.Usuario

@{
    Layout = "";
}

<div class="modal-header">
    <h5 class="modal-title">Nuevo usuario</h5>
    <button class="btn p-1" type="button" data-bs-dismiss="modal" aria-label="Close"><i class="fa fa-times"></i></button>
</div>
<div class="modal-body">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="mb-3">
            <label asp-for="IdUsuario" class="form-label fw-semibold">Usuario</label>
            <input asp-for="IdUsuario" class="form-control" maxlength="15" required />
            <span asp-validation-for="IdUsuario" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="PasswordHash" class="form-label fw-semibold">Contrasena</label>
            <input asp-for="PasswordHash" class="form-control" type="password" maxlength="100" autocomplete="new-password" required />
            <span asp-validation-for="PasswordHash" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="IdPersona" class="form-label fw-semibold">Persona</label>
            <select asp-for="IdPersona" class="form-select" asp-items="ViewBag.IdPersona">
                <option value="">Seleccione...</option>
            </select>
            <span asp-validation-for="IdPersona" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="CodGrupo" class="form-label fw-semibold">Grupo</label>
            <select asp-for="CodGrupo" class="form-select" asp-items="ViewBag.CodGrupo">
                <option value="">Seleccione...</option>
            </select>
            <span asp-validation-for="CodGrupo" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Activo" class="form-label fw-semibold">Activo</label>
            <select asp-for="Activo" class="form-select">
                <option value="S">Si</option>
                <option value="N">No</option>
            </select>
        </div>
        <input type="hidden" asp-for="FecCreacion" />
        <button class="btnAbm" type="submit"><i class="fa fa-save"></i> Guardar</button>
        <button class="btnAbmCancelar" type="button" data-bs-dismiss="modal">Cancelar</button>
    </form>
</div>
