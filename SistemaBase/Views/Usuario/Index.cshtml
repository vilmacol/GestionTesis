@model IEnumerable<SistemaBase.Models.Usuario>

@{
    ViewData["Title"] = "Usuarios";
}

<div class="mx-n4 px-4 mx-lg-n6 px-lg-6 bg-white pt-6 pb-6 border-y border-300">
    <div class="row align-items-end justify-content-between pb-4 g-3">
        <div class="col-auto">
            <h3 class="mb-2">Usuarios</h3>
            <button class="btnAbm" type="button" onclick="openAbmModal('@Url.Action("Create")')"><span class="btn-label"><i class="fa fa-plus"></i></span> Nuevo</button>
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger" role="alert">@TempData["Error"]</div>
    }

    <div class="table-responsive mx-n1 px-1Latest">
        <table class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th class="text-center col-1">Usuario</th>
                    <th>Persona</th>
                    <th>Grupo</th>
                    <th class="text-center">Activo</th>
                    <th>Creacion</th>
                    <th class="text-center col-2"></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="text-center">@item.IdUsuario</td>
                    <td>@(item.IdPersonaNavigation?.Nombre ?? item.IdPersona)</td>
                    <td>@(item.CodGrupoNavigation?.Descripcion ?? item.CodGrupo)</td>
                    <td class="text-center">@item.Activo</td>
                    <td>@item.FecCreacion.ToString("dd/MM/yyyy")</td>
                    <td class="text-center">
                        <button class="btnAbm" type="button" onclick="openAbmModal('@Url.Action("Edit", new { id = item.IdUsuario })')"><i class="fa fa-pencil"></i></button>
                        <button class="btnEliminar" type="button" onclick="openAbmModal('@Url.Action("Delete", new { id = item.IdUsuario })')"><i class="fa fa-trash"></i></button>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="abmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content" id="abmModalContent"></div>
    </div>
</div>

@section Scripts {
    <script>
        async function openAbmModal(url) {
            const response = await fetch(url);
            document.getElementById('abmModalContent').innerHTML = await response.text();
            new bootstrap.Modal(document.getElementById('abmModal')).show();
        }
    </script>
}
